{
  "@context": {
    "@vocab": "https://schema.org/",
    "nhs": "https://digital.nhs.uk/ontology/",
    "fhir": "http://hl7.org/fhir/",
    "hydra": "http://www.w3.org/ns/hydra/core#"
  },
  "@type": "WebAPI",
  "@id": "https://digital.nhs.uk/developer/api-catalogue",
  "name": "NHS API",
  "description": "NHS England's API management platform provides FHIR R4 and REST APIs for healthcare interoperability across the NHS. The platform covers GP Connect (appointment management and access record), Personal Demographics Service, Electronic Prescription Service, Summary Care Records, NHS login (OpenID Connect for citizens), Booking and Referral, Organisation Data Service, and content syndication.",
  "url": "https://digital.nhs.uk/developer",
  "image": "https://digital.nhs.uk/svg/nhs-logo.svg",
  "provider": {
    "@type": "Organization",
    "name": "NHS England",
    "url": "https://www.england.nhs.uk/",
    "contactPoint": {
      "@type": "ContactPoint",
      "email": "api.management@nhs.net",
      "contactType": "Developer Support"
    }
  },
  "documentation": "https://digital.nhs.uk/developer/guides-and-documentation",
  "termsOfService": "https://onboarding.prod.api.platform.nhs.uk/PolicyPages/TermsOfUsePolicy",
  "category": [
    "Healthcare",
    "FHIR",
    "NHS",
    "UK",
    "HL7",
    "Electronic Prescriptions",
    "Patient Demographics",
    "GP Connect",
    "NHS Login",
    "Interoperability"
  ],
  "availableChannel": [
    {
      "@type": "ServiceChannel",
      "name": "Personal Demographics Service - FHIR API",
      "description": "Access and update patient demographic information held in the national NHS patient database.",
      "serviceUrl": "https://api.service.nhs.uk/personal-demographics",
      "serviceType": "FHIR R4"
    },
    {
      "@type": "ServiceChannel",
      "name": "GP Connect Access Record Structured - FHIR API",
      "description": "Retrieve structured clinical records from a patient's registered GP practice.",
      "serviceUrl": "https://api.service.nhs.uk/gp-connect",
      "serviceType": "FHIR STU3/R4"
    },
    {
      "@type": "ServiceChannel",
      "name": "GP Connect Appointment Management - FHIR API",
      "description": "Manage GP practice appointments between different clinical systems.",
      "serviceUrl": "https://api.service.nhs.uk/gp-connect",
      "serviceType": "FHIR"
    },
    {
      "@type": "ServiceChannel",
      "name": "Electronic Prescription Service - FHIR API",
      "description": "Send, track, and manage electronic prescriptions through the NHS Electronic Prescription Service.",
      "serviceUrl": "https://api.service.nhs.uk/electronic-prescriptions",
      "serviceType": "FHIR R4"
    },
    {
      "@type": "ServiceChannel",
      "name": "NHS Login API",
      "description": "OpenID Connect / OAuth 2.0 identity and authentication service for NHS citizens.",
      "serviceUrl": "https://auth.login.nhs.uk",
      "serviceType": "OpenID Connect / OAuth 2.0"
    },
    {
      "@type": "ServiceChannel",
      "name": "Booking and Referral - FHIR API",
      "description": "Send booking and referral information between NHS service providers using the NHS BaRS standard.",
      "serviceUrl": "https://api.service.nhs.uk/booking-and-referral",
      "serviceType": "FHIR R4"
    },
    {
      "@type": "ServiceChannel",
      "name": "Organisation Data Service - FHIR API",
      "description": "Access a comprehensive dataset of NHS health and social care organisations and sites.",
      "serviceUrl": "https://api.service.nhs.uk/organisation-data-service",
      "serviceType": "FHIR R4"
    },
    {
      "@type": "ServiceChannel",
      "name": "NHS Website Content API",
      "description": "Retrieve NHS-approved health information content for syndication into third-party apps.",
      "serviceUrl": "https://api.service.nhs.uk/nhs-website-content",
      "serviceType": "REST"
    },
    {
      "@type": "ServiceChannel",
      "name": "Spine Directory Service - FHIR API",
      "description": "Discover endpoint and accreditation information for NHS Spine-connected organisations.",
      "serviceUrl": "https://api.service.nhs.uk/spine-directory",
      "serviceType": "FHIR"
    },
    {
      "@type": "ServiceChannel",
      "name": "NHS e-Referral Service - FHIR API",
      "description": "Access the NHS e-Referral Service to manage referrals between primary and secondary care.",
      "serviceUrl": "https://api.service.nhs.uk/referrals",
      "serviceType": "FHIR R4"
    },
    {
      "@type": "ServiceChannel",
      "name": "Elective Waiting List API",
      "description": "Access data from the NHS Waiting List Minimum Data Set for patient pathway management.",
      "serviceUrl": "https://api.service.nhs.uk/elective-waiting-list",
      "serviceType": "REST"
    }
  ],
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "NHS API Catalogue",
    "url": "https://digital.nhs.uk/developer/api-catalogue"
  }
}
